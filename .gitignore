# Medical Emergency System - Git Ignore

# Configuration files with sensitive data
config/database.php
config/config.php

# Uploaded files
uploads/*
!uploads/.gitkeep

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
cache/

# Environment files
.env
.env.local

# Backup files
*.bak
*.backup
*.sql.gz
